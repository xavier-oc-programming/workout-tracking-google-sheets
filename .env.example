# =======================
# Nutritionix API credentials
# =======================

# APP_ID — Your Nutritionix App ID.
# To get this:
#   1. Go to https://developer.nutritionix.com/
#   2. Sign up for a free developer account.
#   3. After logging in, create a new app.
#   4. You’ll receive an "App ID" — paste it below.
APP_ID=

# API_KEY — Your Nutritionix API key.
# From the same app you created above, you’ll also get an API key.
# This is used along with your App ID to authenticate requests.
API_KEY=


# =======================
# Sheety Basic Auth credentials
# =======================

# SHEETY_USERNAME — Any username you define for Basic Auth in Sheety.
# When setting up Basic Authentication on Sheety, you choose this value.
# (e.g., workout_user01)
SHEETY_USERNAME=

# SHEETY_PASSWORD — Any password you define for Basic Auth in Sheety.
# Make sure it matches the one set up in the Sheety dashboard for this project.
# (e.g., myexercise01)
SHEETY_PASSWORD=


# =======================
# Sheety API endpoint
# =======================

# SHEET_ENDPOINT — The full Sheety API endpoint for your Google Sheet.
# To get this:
#   1. Go to https://sheety.co/
#   2. Log in and create a new project connected to your Google Sheet.
#   3. Once connected, Sheety provides an endpoint like:
#      https://api.sheety.co/your_id_here/projectName/sheetName
#   4. Copy the full URL and paste it below.
SHEET_ENDPOINT=
