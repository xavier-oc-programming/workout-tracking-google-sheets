# =======================
# Nutritionix API credentials
# =======================

# NUTRITIONIX_APP_ID — Your Nutritionix App ID.
# Dashboard → your app → App ID
NUTRITIONIX_APP_ID=your_nutritionix_app_id_here

# NUTRITIONIX_API_KEY — Your Nutritionix API key.
# Dashboard → your app → API Key
NUTRITIONIX_API_KEY=your_nutritionix_api_key_here


# =======================
# Sheety API endpoint
# =======================

# SHEETY_ENDPOINT — Full endpoint URL for your Google Sheet via Sheety.
# Project page → your endpoint (e.g. https://api.sheety.co/id/projectName/workouts)
SHEETY_ENDPOINT=https://api.sheety.co/your_id/yourProject/workouts


# =======================
# Sheety Basic Auth credentials
# =======================

# SHEETY_USERNAME — The username you set when enabling Basic Auth in Sheety.
SHEETY_USERNAME=your_sheety_username_here

# SHEETY_PASSWORD — The password you set when enabling Basic Auth in Sheety.
SHEETY_PASSWORD=your_sheety_password_here
